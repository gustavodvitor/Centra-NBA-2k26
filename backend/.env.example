# Porta em que a API vai rodar
PORT=3001

# Chave secreta usada para assinar os tokens JWT
# Troque por uma string aleatoria longa em produção
JWT_SECRET=troque-essa-chave-secreta-em-producao

# Tempo de expiracao do token (formato aceito pela lib jsonwebtoken)
JWT_EXPIRES_IN=7d

# Chave da API balldontlie.io (NBA). Hoje em dia ela exige chave mesmo no
# tier gratuito (que cobre apenas times, jogadores e jogos - sem estatisticas).
# Crie sua conta gratis em https://app.balldontlie.io e cole a chave aqui.
BALLDONTLIE_API_KEY=cole-sua-chave-aqui
